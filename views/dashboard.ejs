async function loadAnalytics() {
  try {
    const [features, trend, segments] = await Promise.all([apiFetch('/api/analytics/feature-importance'), apiFetch('/api/analytics/churn-trend'), apiFetch('/api/analytics/risk-segments')]);
    new Chart(document.getElementById('featureChart'), {
      type: 'bar',
      data: { labels: features.map(f => f.feature), datasets: [{ data: features.map(f => parseFloat((f.importance*100).toFixed(1))), backgroundColor: features.map((_, i) => `hsl(${240 + i*15}, 60%, ${62 - i*4}%)`), borderRadius: 4 }] },
      options: { responsive: true, indexAxis: 'y', plugins: { legend: { display: false }, tooltip: { callbacks: { label: ctx => ' ' + ctx.parsed.x + '%' } } }, scales: { x: { grid: { color: '#f0f2fa' }, ticks: { color: '#aaa', font: { size: 11 }, callback: v => v + '%' } }, y: { grid: { display: false }, ticks: { color: '#555', font: { size: 12 } } } } },
    });
    new Chart(document.getElementById('lineChart'), {
      type: 'line',
      data: { labels: trend.map(d => d.name), datasets: [{ label: 'Churned', data: trend.map(d => d.churn), borderColor: '#e74c3c', backgroundColor: 'rgba(231,76,60,0.07)', fill: true, tension: 0.4, pointBackgroundColor: '#e74c3c', pointRadius: 4 }, { label: 'Retained', data: trend.map(d => d.retained), borderColor: '#667eea', backgroundColor: 'rgba(102,126,234,0.07)', fill: true, tension: 0.4, pointBackgroundColor: '#667eea', pointRadius: 4 }] },
      options: { responsive: true, scales: { x: { grid: { display: false }, ticks: { color: '#aaa', font: { size: 11 } } }, y: { grid: { color: '#f0f2fa' }, ticks: { color: '#aaa', font: { size: 11 } } } }, plugins: { legend: { labels: { color: '#888', font: { size: 11 } } } } },
    });
    const hd = segments.find(s => s.name.includes('High'))   || {};
    const md = segments.find(s => s.name.includes('Medium')) || {};
    const ld = segments.find(s => s.name.includes('Low'))    || {};
    document.getElementById('seg-bars').innerHTML =
      [{ name:'High Risk', value: hd.value||0, color:'#e74c3c' }, { name:'Medium Risk', value: md.value||0, color:'#f39c12' }, { name:'Low Risk', value: ld.value||0, color:'#27ae60' }]
      .map(s => '<div class="seg-row"><div class="seg-header"><span class="seg-name">' + s.name + '</span><span class="seg-val" style="color:' + s.color + '">' + s.value + '%</span></div><div class="seg-bg"><div class="seg-fill" style="width:' + s.value + '%;background:' + s.color + ';"></div></div></div>').join('')
      + '<div class="insight-box"><div class="insight-label">📊 Insight</div><div class="insight-text">' + (hd.value||0) + '% of customers are high risk — prioritise immediate outreach to prevent revenue attrition.</div></div>';
  } catch (err) { showToast('Failed to load analytics: ' + err.message, 'error'); }
}

