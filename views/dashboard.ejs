<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ChurnIQ — Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #333; display: flex; height: 100vh; overflow: hidden; }
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: #c5cbe8; border-radius: 10px; }
    :root {
      --bg-card: #ffffff; --bg-card2: #f4f6ff; --border: #e2e6f3;
      --text-main: #333333; --text-muted: #888888; --text-dim: #aaaaaa;
      --blue: #667eea; --blue-light: #764ba2; --purple: #764ba2;
      --red: #e74c3c; --yellow: #f39c12; --green: #27ae60;
    }
    #sidebar {
      width: 220px; min-width: 220px;
      background: #fff;
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column; padding-bottom: 24px;
      transition: width 0.3s ease, min-width 0.3s ease; overflow: hidden; flex-shrink: 0;
      box-shadow: 2px 0 16px rgba(102,126,234,0.10);
    }
    #sidebar.collapsed { width: 64px; min-width: 64px; }
    .sidebar-logo { padding: 26px 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
    .logo-icon { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .logo-text { font-size: 14px; font-weight: 800; color: #333; letter-spacing: -0.3px; line-height: 1.2; white-space: nowrap; transition: opacity 0.2s; }
    .logo-text span { font-size: 10px; color: var(--text-dim); font-weight: 400; }
    #sidebar.collapsed .logo-text { opacity: 0; pointer-events: none; }
    .sidebar-nav { padding: 14px 10px; flex: 1; }
    .nav-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; cursor: pointer; margin-bottom: 3px; border: 1px solid transparent; color: var(--text-muted); transition: all 0.15s; white-space: nowrap; text-decoration: none; }
    .nav-item:hover { background: rgba(102,126,234,0.07); color: #667eea; }
    .nav-item.active { background: linear-gradient(135deg, #667eea, #764ba2); border-color: transparent; color: #fff; }
    .nav-icon { font-size: 16px; width: 20px; text-align: center; flex-shrink: 0; }
    .nav-label { font-size: 13px; font-weight: 500; transition: opacity 0.2s; }
    #sidebar.collapsed .nav-label { opacity: 0; }
    .sidebar-toggle { margin: 0 10px; padding: 8px; border-radius: 8px; background: rgba(102,126,234,0.07); border: 1px solid var(--border); color: var(--text-dim); cursor: pointer; font-size: 12px; display: flex; align-items: center; justify-content: center; }
    #main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    #topbar { padding: 16px 30px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; background: #fff; flex-shrink: 0; box-shadow: 0 2px 8px rgba(102,126,234,0.07); }
    .topbar-title { font-size: 17px; font-weight: 700; color: #333; letter-spacing: -0.4px; }
    .topbar-sub { font-size: 12px; color: var(--text-dim); margin-top: 2px; }
    .topbar-right { display: flex; align-items: center; gap: 12px; }
    .status-badge { padding: 4px 12px; border-radius: 20px; background: rgba(39,174,96,0.1); border: 1px solid rgba(39,174,96,0.3); color: var(--green); font-size: 11px; font-weight: 700; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 800; color: #fff; }
    #content { flex: 1; overflow-y: auto; padding: 26px 30px; }
    .tab-pane { display: none; }
    .tab-pane.active { display: block; }
    .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
    .stat-card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 18px 20px; position: relative; overflow: hidden; box-shadow: 0 2px 12px rgba(102,126,234,0.08); }
    .stat-accent { position: absolute; top: 0; left: 0; right: 0; height: 3px; }
    .stat-label { font-size: 10px; color: var(--text-dim); font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; }
    .stat-value { font-size: 28px; font-weight: 900; color: #333; letter-spacing: -1px; margin: 6px 0 4px; }
    .stat-delta { font-size: 11px; font-weight: 500; }
    .stat-delta.pos { color: var(--green); } .stat-delta.neg { color: var(--red); } .stat-delta.neu { color: var(--text-muted); }
    .card { background: #fff; border: 1px solid var(--border); border-radius: 14px; padding: 20px 22px; box-shadow: 0 2px 12px rgba(102,126,234,0.08); }
    .card-title { font-size: 11px; font-weight: 700; color: #999; text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 16px; }
    .charts-row { display: grid; grid-template-columns: 1.6fr 1fr; gap: 14px; margin-bottom: 20px; }
    .mb-20 { margin-bottom: 20px; }
    .pred-table { width: 100%; border-collapse: collapse; }
    .pred-table th { font-size: 10px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.7px; padding: 8px 12px; text-align: left; }
    .pred-table td { padding: 11px 12px; font-size: 13px; color: #555; border-top: 1px solid #f0f2fa; }
    .pred-table tr:hover td { background: rgba(102,126,234,0.03); }
    .pred-table tr td:first-child { color: #667eea; font-weight: 600; font-size: 12px; }
    .risk-tag { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
    .risk-tag.High   { background: rgba(231,76,60,0.10);  color: #e74c3c; border: 1px solid rgba(231,76,60,0.25); }
    .risk-tag.Medium { background: rgba(243,156,18,0.10); color: #f39c12; border: 1px solid rgba(243,156,18,0.25); }
    .risk-tag.Low    { background: rgba(39,174,96,0.10);  color: #27ae60; border: 1px solid rgba(39,174,96,0.25); }
    .prob-bar-wrap { display: flex; align-items: center; gap: 8px; }
    .prob-bar-bg { flex: 1; height: 4px; border-radius: 2px; background: var(--border); }
    .prob-bar { height: 100%; border-radius: 2px; }
    .form-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }
    .form-group label { display: block; font-size: 10px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.7px; margin-bottom: 6px; }
    .form-group input, .form-group select { width: 100%; padding: 10px 13px; border-radius: 8px; background: #fff; border: 1.5px solid var(--border); color: #333; font-size: 13px; font-family: 'Segoe UI', sans-serif; outline: none; transition: border-color 0.15s; }
    .form-group input:focus, .form-group select:focus { border-color: #667eea; }
    .form-group select option { background: #fff; color: #333; }
    .btn-primary { padding: 11px 26px; border-radius: 10px; font-weight: 700; font-size: 13px; cursor: pointer; border: none; background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; font-family: 'Segoe UI', sans-serif; transition: opacity 0.15s, transform 0.15s; }
    .btn-primary:hover { opacity: 0.9; transform: translateY(-1px); } .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .btn-outline { padding: 11px 20px; border-radius: 10px; font-weight: 600; font-size: 13px; cursor: pointer; background: rgba(102,126,234,0.07); border: 1.5px solid rgba(102,126,234,0.35); color: #667eea; font-family: 'Segoe UI', sans-serif; transition: all 0.15s; }
    .btn-outline:hover { background: rgba(102,126,234,0.14); }
    .upload-strip { display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 16px 18px; border-radius: 10px; margin-bottom: 24px; border: 1.5px dashed #c5cbe8; background: rgba(102,126,234,0.03); }
    .upload-strip-info h4 { font-size: 13px; color: #555; font-weight: 600; margin-bottom: 3px; }
    .upload-strip-info p { font-size: 11px; color: var(--text-dim); }
    #result-card { display: none; margin-top: 22px; padding: 22px 24px; border-radius: 14px; }
    #result-card.High   { background: rgba(231,76,60,0.05);  border: 1px solid rgba(231,76,60,0.2); }
    #result-card.Medium { background: rgba(243,156,18,0.05); border: 1px solid rgba(243,156,18,0.2); }
    #result-card.Low    { background: rgba(39,174,96,0.05);  border: 1px solid rgba(39,174,96,0.2); }
    .result-top { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px; margin-bottom: 18px; }
    .result-prob { font-size: 44px; font-weight: 900; letter-spacing: -2px; line-height: 1; }
    .result-prob-label { font-size: 12px; color: var(--text-muted); margin-top: 4px; }
    .result-right { text-align: right; }
    .result-label-title { font-size: 11px; color: var(--text-dim); font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 6px; }
    .result-churn { font-size: 20px; font-weight: 900; }
    .strategy-box { padding: 14px 16px; border-radius: 10px; background: rgba(102,126,234,0.05); border: 1px solid rgba(102,126,234,0.15); }
    .strategy-box-label { font-size: 10px; color: var(--text-dim); font-weight: 700; text-transform: uppercase; letter-spacing: 0.7px; margin-bottom: 6px; }
    .strategy-box-text { font-size: 14px; font-weight: 600; color: #333; }
    .model-table { width: 100%; border-collapse: collapse; }
    .model-table th { font-size: 10px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.7px; padding: 8px 14px; text-align: left; }
    .model-table td { padding: 13px 14px; font-size: 13px; color: #555; border-top: 1px solid #f0f2fa; }
    .model-table tr.best-model td { color: #667eea; }
    .model-table tr.best-model { background: rgba(102,126,234,0.05); }
    .best-badge { font-size: 10px; background: rgba(39,174,96,0.12); color: var(--green); padding: 2px 7px; border-radius: 10px; font-weight: 700; margin-left: 6px; }
    .metric-mini-bar { height: 3px; border-radius: 2px; background: var(--border); margin-top: 4px; }
    .metric-mini-bar-fill { height: 100%; border-radius: 2px; }
    .strategy-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 20px; }
    .strategy-card { border-radius: 14px; padding: 22px; background: #fff; box-shadow: 0 2px 12px rgba(102,126,234,0.08); }
    .strategy-card.High   { border: 1px solid rgba(231,76,60,0.2); }
    .strategy-card.Medium { border: 1px solid rgba(243,156,18,0.2); }
    .strategy-card.Low    { border: 1px solid rgba(39,174,96,0.2); }
    .strategy-icon { font-size: 30px; margin-bottom: 12px; }
    .strategy-title { font-size: 16px; font-weight: 800; margin-bottom: 8px; }
    .strategy-title.High { color: var(--red); } .strategy-title.Medium { color: var(--yellow); } .strategy-title.Low { color: var(--green); }
    .strategy-desc { font-size: 13px; color: var(--text-dim); line-height: 1.6; }
    .action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .action-group { padding: 16px 18px; border-radius: 10px; }
    .action-group.high-g   { background: rgba(231,76,60,0.04);  border: 1px solid rgba(231,76,60,0.12); }
    .action-group.medium-g { background: rgba(243,156,18,0.04); border: 1px solid rgba(243,156,18,0.12); }
    .action-group-title { font-size: 12px; font-weight: 700; margin-bottom: 10px; }
    .action-group-title.high-t { color: var(--red); } .action-group-title.medium-t { color: var(--yellow); }
    .action-item { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 8px; font-size: 13px; color: #666; }
    .action-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 5px; }
    .seg-row { margin-bottom: 14px; }
    .seg-header { display: flex; justify-content: space-between; margin-bottom: 5px; }
    .seg-name { font-size: 12px; color: #555; font-weight: 600; }
    .seg-val { font-size: 12px; font-weight: 700; }
    .seg-bg { height: 6px; border-radius: 3px; background: var(--border); }
    .seg-fill { height: 100%; border-radius: 3px; transition: width 1.2s cubic-bezier(0.4,0,0.2,1); }
    .insight-box { margin-top: 18px; padding: 12px 14px; border-radius: 10px; background: rgba(102,126,234,0.06); border: 1px solid rgba(102,126,234,0.18); }
    .insight-label { font-size: 12px; font-weight: 700; color: #667eea; margin-bottom: 4px; }
    .insight-text { font-size: 12px; color: var(--text-dim); line-height: 1.5; }
    .pagination { display: flex; align-items: center; gap: 6px; margin-top: 14px; justify-content: flex-end; }
    .page-btn { padding: 5px 11px; border-radius: 7px; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid var(--border); background: #fff; color: var(--text-muted); transition: all 0.12s; }
    .page-btn:hover { background: rgba(102,126,234,0.07); color: #667eea; }
    .page-btn.current { background: linear-gradient(135deg, #667eea, #764ba2); border-color: transparent; color: #fff; }
    .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .filter-row { display: flex; gap: 10px; align-items: center; margin-bottom: 14px; flex-wrap: wrap; }
    .filter-row input, .filter-row select { padding: 7px 12px; border-radius: 8px; font-size: 12px; background: #fff; border: 1.5px solid var(--border); color: #333; outline: none; font-family: 'Segoe UI', sans-serif; }
    .filter-row input:focus, .filter-row select:focus { border-color: #667eea; }
    .filter-row select option { background: #fff; }
    .spinner { display: inline-block; width: 14px; height: 14px; border: 2px solid rgba(102,126,234,0.2); border-top-color: #667eea; border-radius: 50%; animation: spin 0.6s linear infinite; vertical-align: middle; margin-right: 6px; }
    @keyframes spin { to { transform: rotate(360deg); } }
    #toast { position: fixed; bottom: 24px; right: 24px; z-index: 999; padding: 12px 18px; border-radius: 10px; font-size: 13px; font-weight: 600; display: none; animation: fadeUp 0.3s ease; }
    #toast.success { background: rgba(39,174,96,0.95); color: #fff; }
    #toast.error   { background: rgba(231,76,60,0.95); color: #fff; }
    @keyframes fadeUp { from { transform: translateY(10px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    @media (max-width: 1100px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } .charts-row { grid-template-columns: 1fr; } .form-grid { grid-template-columns: repeat(2, 1fr); } .strategy-cards { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 720px)  { .stats-grid { grid-template-columns: 1fr 1fr; } .form-grid { grid-template-columns: 1fr; } .action-grid { grid-template-columns: 1fr; } #content { padding: 16px; } }
    /* ── Big Data tab ─────────────────────────────────────────────────────────── */
    .arch-diagram { display: flex; flex-direction: column; align-items: center; padding: 20px 0; }
    .arch-node { display: flex; align-items: center; justify-content: center; width: 230px; padding: 11px 18px; border-radius: 10px; font-weight: 700; font-size: 13px; text-align: center; }
    .arch-arrow { font-size: 18px; color: #c5cbe8; margin: 3px 0; line-height: 1; }
    .arch-sublabel { font-size: 9px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 3px; font-weight: 700; }
    .pipeline-steps { display: flex; align-items: center; flex-wrap: wrap; justify-content: center; gap: 0; margin: 16px 0 10px; }
    .pipeline-step { display: flex; flex-direction: column; align-items: center; gap: 6px; padding: 14px 18px; border-radius: 10px; background: rgba(102,126,234,0.05); border: 1.5px solid rgba(102,126,234,0.15); min-width: 110px; text-align: center; transition: all 0.3s; }
    .pipeline-step.active { background: linear-gradient(135deg, rgba(102,126,234,0.18), rgba(118,75,162,0.18)); border-color: #667eea; box-shadow: 0 2px 10px rgba(102,126,234,0.18); }
    .pipeline-step-icon { font-size: 20px; }
    .pipeline-step-name { font-size: 11px; font-weight: 700; color: #555; }
    .pipeline-step.active .pipeline-step-name { color: #667eea; }
    .pipeline-arrow-h { font-size: 18px; color: #c5cbe8; padding: 0 6px; }
    .proc-stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-top: 18px; }
    .proc-stat-item { background: rgba(102,126,234,0.06); border: 1px solid rgba(102,126,234,0.18); border-radius: 10px; padding: 14px 12px; text-align: center; }
    .proc-stat-value { font-size: 22px; font-weight: 900; color: #667eea; letter-spacing: -0.5px; }
    .proc-stat-label { font-size: 10px; color: var(--text-dim); font-weight: 700; text-transform: uppercase; letter-spacing: 0.7px; margin-top: 4px; }
    .log-panel { background: #12122a; border-radius: 10px; padding: 14px 16px; font-family: 'Courier New', monospace; font-size: 11.5px; color: #8892b0; max-height: 200px; overflow-y: auto; line-height: 1.6; }
    .log-line.ok   { color: #68d391; }
    .log-line.info { color: #63b3ed; }
    .log-line.warn { color: #f6e05e; }
    .dataset-toggle { display: flex; gap: 0; border-radius: 8px; overflow: hidden; border: 1.5px solid var(--border); width: fit-content; margin-bottom: 12px; }
    .dataset-toggle-btn { padding: 8px 18px; font-size: 12px; font-weight: 600; cursor: pointer; border: none; background: #fff; color: var(--text-muted); font-family: 'Segoe UI', sans-serif; transition: all 0.15s; }
    .dataset-toggle-btn.active { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; }
    .mini-dash-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; margin-bottom: 14px; }
    .mini-dash-card { background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 14px 16px; box-shadow: 0 2px 8px rgba(102,126,234,0.06); }
    .mini-dash-label { font-size: 10px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.7px; }
    .mini-dash-value { font-size: 22px; font-weight: 900; color: #333; margin: 5px 0 2px; letter-spacing: -0.5px; }
    .mini-dash-sub { font-size: 11px; color: var(--text-muted); }
    .bd-upload-zone { border: 1.5px dashed #c5cbe8; border-radius: 10px; padding: 22px; text-align: center; background: rgba(102,126,234,0.02); margin-bottom: 14px; }
  </style>
</head>
<body>

<nav id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon">⬡</div>
    <div class="logo-text">ChurnIQ<br><span>Team 25 · <%= user.name %></span></div>
  </div>
  <div class="sidebar-nav">
    <a class="nav-item active" data-tab="overview"   href="#"><span class="nav-icon">⬡</span><span class="nav-label">Overview</span></a>
    <a class="nav-item" data-tab="predict"    href="#"><span class="nav-icon">◎</span><span class="nav-label">Predict</span></a>
    <a class="nav-item" data-tab="analytics"  href="#"><span class="nav-icon">▦</span><span class="nav-label">Analytics</span></a>
    <a class="nav-item" data-tab="models"     href="#"><span class="nav-icon">◈</span><span class="nav-label">Models</span></a>
    <a class="nav-item" data-tab="strategies" href="#"><span class="nav-icon">⬗</span><span class="nav-label">Strategies</span></a>
    <a class="nav-item" data-tab="bigdata"    href="#"><span class="nav-icon">◉</span><span class="nav-label">Big Data</span></a>
  </div>
  <button class="sidebar-toggle" id="toggleSidebar">◀</button>
</nav>

<div id="main">
  <div id="topbar">
    <div>
      <div class="topbar-title" id="tab-title">Overview</div>
      <div class="topbar-sub"   id="tab-sub">System-wide churn metrics and recent predictions</div>
    </div>
    <div class="topbar-right">
      <div class="status-badge">● Model Active</div>
      <div class="avatar"><%= user.name ? user.name[0].toUpperCase() : 'U' %></div>
      <a href="/logout" style="font-size:12px;color:#888;text-decoration:none;">Sign out</a>
    </div>
  </div>

  <div id="content">

    <!-- OVERVIEW -->
    <div class="tab-pane active" id="tab-overview">
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-accent" style="background:linear-gradient(90deg,#667eea,transparent)"></div><div class="stat-label">Total Customers</div><div class="stat-value" id="stat-total">—</div><div class="stat-delta neu" id="stat-total-delta">Loading…</div></div>
        <div class="stat-card"><div class="stat-accent" style="background:linear-gradient(90deg,#e74c3c,transparent)"></div><div class="stat-label">Churn Rate</div><div class="stat-value" id="stat-churn-rate">—</div><div class="stat-delta" id="stat-churn-delta">Loading…</div></div>
        <div class="stat-card"><div class="stat-accent" style="background:linear-gradient(90deg,#f39c12,transparent)"></div><div class="stat-label">High Risk Customers</div><div class="stat-value" id="stat-high-risk">—</div><div class="stat-delta neg" id="stat-high-delta">Loading…</div></div>
        <div class="stat-card"><div class="stat-accent" style="background:linear-gradient(90deg,#27ae60,transparent)"></div><div class="stat-label">Model Accuracy</div><div class="stat-value" id="stat-accuracy">—</div><div class="stat-delta neu" id="stat-model-name">Loading…</div></div>
      </div>
      <div class="charts-row">
        <div class="card"><div class="card-title">Monthly Churn vs Retained</div><canvas id="churnTrendChart" height="200"></canvas></div>
        <div class="card"><div class="card-title">Risk Distribution</div><canvas id="riskPieChart" height="200"></canvas></div>
      </div>
      <div class="card">
        <div class="card-title">Recent Predictions</div>
        <div class="filter-row">
