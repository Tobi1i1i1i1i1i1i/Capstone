    document.querySelector('#model-table tbody').innerHTML = models.map(m =>
      '<tr class="' + (m.selected?'best-model':'') + '"><td>' + esc(m.model) + (m.selected?'<span class="best-badge">BEST</span>':'') + '</td>' +
      ['accuracy','precision','recall','f1'].map(k => '<td><div style="font-weight:700;">' + m[k] + '%</div><div class="metric-mini-bar"><div class="metric-mini-bar-fill" style="width:' + m[k] + '%;background:' + (m.selected?'#667eea':'#c5cbe8') + ';"></div></div></td>').join('') + '</tr>'
    ).join('');
    const colors = ['#667eea','#764ba2','#e74c3c','#f39c12','#27ae60','#888'];
    new Chart(document.getElementById('radarChart'), {
      type: 'radar',
      data: { labels: ['Accuracy','Precision','Recall','F1-Score'], datasets: models.map((m,i) => ({ label: m.model, data: [m.accuracy,m.precision,m.recall,m.f1], borderColor: colors[i]||'#888', backgroundColor: (colors[i]||'#888')+'22', borderWidth: 2, pointBackgroundColor: colors[i]||'#888' })) },
      options: { responsive: true, scales: { r: { min: 70, max: 100, grid: { color: '#e2e6f3' }, pointLabels: { color: '#888', font: { size: 11 } }, ticks: { color: '#aaa', font: { size: 9 }, backdropColor: 'transparent' } } }, plugins: { legend: { position: 'bottom', labels: { color: '#888', font: { size: 11 }, padding: 12 } } } },
    });
  } catch (err) { showToast('Failed to load models: ' + err.message, 'error'); }
}

function animateNumber(id, target, decimals, suffix) {
  const el = document.getElementById(id); if (!el) return;
  let current = 0; const step = target / (1000/16);
  const timer = setInterval(() => { current += step; if (current >= target) { el.textContent = parseFloat(target).toFixed(decimals) + suffix; clearInterval(timer); } else { el.textContent = current.toFixed(decimals) + suffix; } }, 16);
}
function esc(str) { return String(str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

// ── Big Data tab ──────────────────────────────────────────────────────────────
async function loadBigData() {
  await loadBatchStats();
}

async function loadBatchStats() {
  try {
    const stats = await apiFetch('/api/batch-stats');
    document.getElementById('bd-churn-rate').textContent = stats.avgChurnRate + '%';
    document.getElementById('bd-high-risk').textContent  = stats.highRiskCount.toLocaleString();
    document.getElementById('bd-total').textContent      = stats.totalProcessed.toLocaleString();
  } catch (_) {}
}

function setDatasetMode(mode, btn) {
  document.querySelectorAll('.dataset-toggle-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const info = document.getElementById('dataset-mode-info');
  info.textContent = mode === 'full'
    ? 'Using full dataset — all records included in predictions.'
    : 'Sample mode active — processing 10% representative subset for faster results.';
}

function appendLog(msg, type) {
  const log  = document.getElementById('preprocess-log');
  if (!log) return;
  const line = document.createElement('div');
  line.className = 'log-line' + (type ? ' ' + type : '');
  const ts = new Date().toLocaleTimeString('en-GB', { hour12: false });
  line.textContent = '[' + ts + '] ' + msg;
  log.appendChild(line);
  log.scrollTop = log.scrollHeight;
}

function animatePipeline(upTo) {
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('pipe-' + i);
    if (el) el.classList.toggle('active', i <= upTo);
  }
}

document.getElementById('bd-csv-input').addEventListener('change', async function () {
  if (!this.files.length) return;
  const file = this.files[0];
  const btn  = document.getElementById('bd-upload-btn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Processing…';

  // Reset UI
  document.getElementById('preprocess-log').innerHTML = '';
  document.getElementById('proc-stats').style.display = 'none';
  animatePipeline(1);

  appendLog('File received: ' + file.name + ' (' + (file.size / 1024).toFixed(1) + ' KB)', 'info');
  appendLog('Validating CSV structure and required columns…', 'info');
  setTimeout(() => { animatePipeline(2); appendLog('Missing values handled — filled with column defaults', 'ok'); appendLog('Data normalised for model input (StandardScaler)', 'ok'); }, 500);
  setTimeout(() => { animatePipeline(3); appendLog('Chunk-based prediction started (chunk size: 1,000 rows)…', 'info'); }, 1100);

  const form = new FormData();
  form.append('dataset', file);

  try {
    const res  = await fetch('/api/upload', { method: 'POST', body: form });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error);

    animatePipeline(4);
    appendLog(data.saved + ' predictions generated and saved to database', 'ok');
    if (data.errors > 0) appendLog(data.errors + ' rows skipped (missing required fields)', 'warn');
    appendLog('Total time: ' + data.processingTimeSec + 's | Chunks: ' + data.chunksProcessed + ' | Avg: ' + data.avgPredictionTimeMs + 'ms/record', 'ok');

    // Show processing stats panel
    document.getElementById('ps-records').textContent = (data.totalRows || data.saved).toLocaleString();
    document.getElementById('ps-time').textContent    = data.processingTimeSec;
    document.getElementById('ps-chunks').textContent  = data.chunksProcessed;
    document.getElementById('ps-avg').textContent     = data.avgPredictionTimeMs;
    document.getElementById('ps-summary').textContent =
      'Processed ' + (data.totalRows || data.saved).toLocaleString() + ' records in ' + data.processingTimeSec + ' seconds';
    document.getElementById('proc-stats').style.display = 'block';

    showToast('✓ ' + data.saved + ' predictions saved in ' + data.processingTimeSec + 's');
    await loadBatchStats();
  } catch (err) {
    appendLog('Error: ' + err.message, 'warn');
    animatePipeline(1);
    showToast('Upload failed: ' + err.message, 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = 'Upload &amp; Predict';
    this.value = '';
  }
});

