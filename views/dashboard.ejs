<script>
const TAB_META = {
  overview:   { title: 'Overview',             sub: 'System-wide churn metrics and recent predictions' },
  predict:    { title: 'Predict Churn',         sub: 'Run single or batch predictions on customer records' },
  analytics:  { title: 'Analytics',            sub: 'Feature importance, risk segments & churn trends' },
  models:     { title: 'Model Evaluation',     sub: 'Compare classification & ensemble model performance' },
  strategies: { title: 'Retention Strategies', sub: 'Risk-based action playbook for customer retention' },
  bigdata:    { title: 'Big Data Processing',  sub: 'Batch predictions, chunk processing & data pipeline' },
};
let chartsInit = {};

document.getElementById('toggleSidebar').addEventListener('click', function () {
  const sb = document.getElementById('sidebar');
  const collapsed = sb.classList.toggle('collapsed');
  this.textContent = collapsed ? '▶' : '◀';
});

document.querySelectorAll('.nav-item').forEach(el => {
  el.addEventListener('click', function (e) {
    e.preventDefault();
    const tab = this.dataset.tab;
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    this.classList.add('active');
    document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
    document.getElementById('tab-' + tab).classList.add('active');
    document.getElementById('tab-title').textContent = TAB_META[tab].title;
    document.getElementById('tab-sub').textContent   = TAB_META[tab].sub;
    if (tab === 'analytics' && !chartsInit.analytics) { loadAnalytics();  chartsInit.analytics = true; }
    if (tab === 'models'    && !chartsInit.models)    { loadModels();     chartsInit.models    = true; }
    if (tab === 'bigdata'   && !chartsInit.bigdata)   { loadBigData();    chartsInit.bigdata   = true; }
  });
});

function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = type; t.style.display = 'block';
  setTimeout(() => { t.style.display = 'none'; }, 3500);
}

async function apiFetch(url, opts = {}) {
  const res = await fetch(url, { headers: { 'Content-Type': 'application/json', ...opts.headers }, ...opts });
  if (!res.ok) { const err = await res.json().catch(() => ({ error: 'Unknown error' })); throw new Error(err.error || res.statusText); }
  return res.json();
}

Chart.defaults.color = '#888888';
Chart.defaults.font.family = "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif";

async function loadOverview() {
  try {
    const [stats, trend, segments] = await Promise.all([
      apiFetch('/api/stats'),
      apiFetch('/api/analytics/churn-trend'),
      apiFetch('/api/analytics/risk-segments'),
    ]);
    animateNumber('stat-total',      stats.totalCustomers, 0, '');
    animateNumber('stat-churn-rate', stats.churnRate,      1, '%');
    animateNumber('stat-high-risk',  stats.highRiskCount,  0, '');
    animateNumber('stat-accuracy',   stats.modelAccuracy,  1, '%');
    document.getElementById('stat-total-delta').textContent  = stats.totalPredictions + ' predictions run';
    document.getElementById('stat-model-name').textContent   = stats.modelName;
    document.getElementById('stat-high-delta').textContent   = stats.highRiskCount + ' flagged for intervention';
    const delta = stats.churnDelta;
    const deltaEl = document.getElementById('stat-churn-delta');
    if (delta !== null) { deltaEl.textContent = (delta > 0 ? '▲' : '▼') + ' ' + Math.abs(delta) + '% vs last month'; deltaEl.className = 'stat-delta ' + (delta > 0 ? 'neg' : 'pos'); }
    else { deltaEl.textContent = 'No prior month data'; deltaEl.className = 'stat-delta neu'; }

    new Chart(document.getElementById('churnTrendChart'), {
      type: 'bar',
      data: { labels: trend.map(d => d.name), datasets: [
        { label: 'Churned',  data: trend.map(d => d.churn),    backgroundColor: '#e74c3c', borderRadius: 4 },
        { label: 'Retained', data: trend.map(d => d.retained), backgroundColor: '#667eea', borderRadius: 4 },
      ]},
      options: { responsive: true, maintainAspectRatio: true, scales: { x: { grid: { display: false }, ticks: { color: '#aaa', font: { size: 11 } } }, y: { grid: { color: '#f0f2fa' }, ticks: { color: '#aaa', font: { size: 11 } } } }, plugins: { legend: { labels: { color: '#888', font: { size: 11 } } } } },
    });

    new Chart(document.getElementById('riskPieChart'), {
      type: 'doughnut',
      data: { labels: segments.map(s => s.name), datasets: [{ data: segments.map(s => s.value), backgroundColor: segments.map(s => s.color), borderWidth: 0, hoverOffset: 6 }] },
      options: { responsive: true, cutout: '62%', plugins: { legend: { position: 'bottom', labels: { color: '#888', font: { size: 11 }, padding: 14 } }, tooltip: { callbacks: { label: ctx => ' ' + ctx.label + ': ' + ctx.parsed + '%' } } } },
    });

    await loadPredictions(1);
  } catch (err) { showToast('Failed to load overview: ' + err.message, 'error'); }
}

async function loadPredictions(page) {
  const search = document.getElementById('search-input').value.trim();
  const risk   = document.getElementById('risk-filter').value;
  const churn  = document.getElementById('churn-filter').value;
  const params = new URLSearchParams({ page, limit: 10 });
  if (search) params.set('search', search);
  if (risk)   params.set('risk', risk);
  if (churn)  params.set('churn', churn);
  const tbody = document.getElementById('pred-tbody');
  tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#aaa;padding:22px;"><span class="spinner"></span>Loading…</td></tr>';
  try {
    const { predictions, pagination } = await apiFetch('/api/predictions?' + params);
    if (!predictions.length) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#aaa;padding:30px;">No predictions yet. Run one from the Predict tab.</td></tr>'; document.getElementById('pagination').innerHTML = ''; return; }
    tbody.innerHTML = predictions.map(p => {
      const pct    = (p.churn_probability * 100).toFixed(1);
      const barCol = p.risk_category === 'High' ? '#e74c3c' : p.risk_category === 'Medium' ? '#f39c12' : '#27ae60';
      const date   = new Date(p.createdAt).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
      return '<tr><td>' + esc(p.customer_id) + '</td><td>' + esc(p.customer_name) + '</td><td><span class="risk-tag ' + p.risk_category + '">' + p.risk_category + '</span></td><td><div class="prob-bar-wrap"><span style="font-size:13px;font-weight:700;color:' + barCol + ';min-width:42px;">' + pct + '%</span><div class="prob-bar-bg"><div class="prob-bar" style="width:' + pct + '%;background:' + barCol + ';"></div></div></div></td><td style="color:' + (p.churn_prediction ? '#e74c3c' : '#27ae60') + ';font-weight:700;">' + (p.churn_prediction ? 'Will Churn' : 'Will Retain') + '</td><td style="font-size:12px;color:#aaa;">' + esc(p.recommended_strategy) + '</td><td style="font-size:12px;color:#aaa;">' + date + '</td></tr>';
    }).join('');
    const pg = document.getElementById('pagination');
    const { totalPages } = pagination;
    if (totalPages <= 1) { pg.innerHTML = ''; return; }
    let btns = '<button class="page-btn" onclick="loadPredictions(' + (page-1) + ')" ' + (page===1?'disabled':'') + '>‹ Prev</button>';
    for (let i = 1; i <= totalPages; i++) {
      if (i === 1 || i === totalPages || Math.abs(i - page) <= 1) btns += '<button class="page-btn ' + (i===page?'current':'') + '" onclick="loadPredictions(' + i + ')">' + i + '</button>';
      else if (Math.abs(i - page) === 2) btns += '<span style="color:#aaa;padding:0 4px;">…</span>';
    }
    btns += '<button class="page-btn" onclick="loadPredictions(' + (page+1) + ')" ' + (page===totalPages?'disabled':'') + '>Next ›</button>';
    pg.innerHTML = btns;
  } catch (err) { tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#e74c3c;padding:22px;">Error: ' + esc(err.message) + '</td></tr>'; }
}

