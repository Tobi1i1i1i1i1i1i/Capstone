# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Docker:     mongodb://mongo:27017/loginpage
# Local dev:  mongodb://localhost:27017/loginpage
MONGODB_URI=mongodb://localhost:27017/loginpage

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=your-super-secret-key-change-this

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get credentials from https://console.cloud.google.com/apis/credentials
# Authorised redirect URI must be: http://<your-host>:3000/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ── Flask ML API ──────────────────────────────────────────────────────────────
# Docker:     http://ml:5000  (set automatically by compose.yaml — do not change)
# Local dev:  http://localhost:5000
ML_API_URL=http://localhost:5000
MODEL_PATH=ml/model.pkl
SCALER_PATH=ml/scaler.pkl
